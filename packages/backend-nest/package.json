    "@nestjs/websockets": "^11.0.0",
    "dotenv": "^16.4.0",
    "reflect-metadata": "^0.2.2",
    "redis": "^4.7.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
